      {/* VISTA: Programas */}
      {activeView === "programs" && (
        <ProgramManagement darkMode={darkMode} />
      )}

      {/* OLD Programs View - DEPRECATED */}
      {false && activeView === "programs_old" && (
        <div className="space-y-4">
          {/* Botón crear programa */}
          <div className="flex justify-between items-center">
            <div>
              <h2 className="text-2xl font-bold">Programas</h2>
              <p className={`text-sm ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                {programs.length} programas activos
              </p>
            </div>
            <button
              onClick={() => setProgramModalOpen(true)}
              className="rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-semibold text-black transition hover:bg-primary-400 hover:shadow-lg flex items-center justify-center gap-2"
            >
              <IconProgram className="w-4 h-4" />
              Crear Programa
            </button>
          </div>

          {/* Tabla de programas */}
          <div className={`rounded-xl border ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-white"}`}>
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead className={`border-b ${darkMode ? "border-gray-800" : "border-gray-200"}`}>
                  <tr>
                    <th className={`px-6 py-3 text-left text-xs font-medium uppercase tracking-wider ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                      Programa
                    </th>
                    <th className={`px-6 py-3 text-left text-xs font-medium uppercase tracking-wider ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                      Tipo
                    </th>
                    <th className={`px-6 py-3 text-left text-xs font-medium uppercase tracking-wider ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                      Matches
                    </th>
                    <th className={`px-6 py-3 text-left text-xs font-medium uppercase tracking-wider ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                      Estado
                    </th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-gray-800">
                  {programs.map((program) => (
                    <tr key={program.id} className={darkMode ? "hover:bg-dark-300" : "hover:bg-gray-50"}>
                      <td className="px-6 py-4">
                        <div className="font-medium">{program.name}</div>
                        <div className={`text-sm ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                          {program.description?.substring(0, 50)}...
                        </div>
                      </td>
                      <td className="px-6 py-4 text-sm">
                        <span className="inline-flex rounded-full px-2 py-1 text-xs font-semibold bg-primary-500/20 text-primary-500">
                          Mentoría
                        </span>
                      </td>
                      <td className="px-6 py-4 text-sm">
                        {matches.filter(m => m.id).length}
                      </td>
                      <td className="px-6 py-4 text-sm">
                        <span className="inline-flex rounded-full bg-green-500/20 px-2 py-1 text-xs font-semibold text-green-400">
                          Activo
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      {/* VISTA: Participantes */}
      {activeView === "participants" && (
        <div className="space-y-4">
          {/* Header con botón */}
          <div className="flex justify-between items-center">
            <div>
              <h2 className="text-2xl font-bold">Participantes</h2>
              <p className={`text-sm ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                {participants.length} participantes ({mentors.length} mentores, {mentees.length} mentees)
              </p>
            </div>
            <div className="flex gap-2">
              <button
                onClick={() => setCSVModalOpen(true)}
                className={`rounded-lg border px-4 py-2.5 text-sm font-semibold transition flex items-center justify-center gap-2 ${
                  darkMode
                    ? "border-gray-600 text-gray-300 hover:border-primary-500 hover:bg-primary-500/10"
                    : "border-gray-300 text-gray-700 hover:border-primary-500 hover:bg-primary-500/10"
                }`}
              >
                <IconDocument className="w-4 h-4" />
                Importar CSV
              </button>
              <button
                onClick={() => setParticipantModalOpen(true)}
                className="rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-semibold text-black transition hover:bg-primary-400 hover:shadow-lg flex items-center justify-center gap-2"
              >
                <IconParticipants className="w-4 h-4" />
                Agregar Participante
              </button>
            </div>
          </div>

          {/* Filtros - Comentado temporalmente
          <FilterBar filters={filters} onFilterChange={setFilters} darkMode={darkMode} />
          */}

          {/* Tabla de participantes */}
          <div className={`rounded-xl border ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-white"}`}>
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead className={`border-b ${darkMode ? "border-gray-800" : "border-gray-200"}`}>
                  <tr>
                    <th className={`px-6 py-3 text-left text-xs font-medium uppercase tracking-wider ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                      Participante
                    </th>
                    <th className={`px-6 py-3 text-left text-xs font-medium uppercase tracking-wider ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                      Rol
                    </th>
                    <th className={`px-6 py-3 text-left text-xs font-medium uppercase tracking-wider ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                      Email
                    </th>
                    <th className={`px-6 py-3 text-left text-xs font-medium uppercase tracking-wider ${darkMode ? "text-gray-400" : "text-gray-500"}`}>
                      Matches
                    </th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-gray-800">
                  {filteredParticipants.map((participant) => (
                    <tr key={participant.id} className={darkMode ? "hover:bg-dark-300" : "hover:bg-gray-50"}>
                      <td className="px-6 py-4">
                        <div className="font-medium">{participant.full_name}</div>
                      </td>
                      <td className="px-6 py-4 text-sm">
                        <span className={`inline-flex rounded-full px-2 py-1 text-xs font-semibold ${
                          participant.role === "mentor"
                            ? "bg-primary-500/20 text-primary-500"
                            : "bg-blue-500/20 text-blue-400"
                        }`}>
                          {participant.role}
                        </span>
                      </td>
                      <td className="px-6 py-4 text-sm">N/A</td>
                      <td className="px-6 py-4 text-sm">
                        {matches.filter(m => 
                          m.mentor.id === participant.id || m.mentee.id === participant.id
                        ).length}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      {/* VISTA: Matches - Nuevo Motor IA */}
      {activeView === "matches" && (
        <MatchingEngineAI darkMode={darkMode} />
      )}

      {/* VISTA: Calendario */}
      {activeView === "calendar" && (
        <div>
          <h2 className="text-2xl font-bold mb-4">Calendario de Sesiones</h2>
          <CalendarView matches={matches} darkMode={darkMode} />
        </div>
      )}

      {/* VISTA: Analytics */}
      {activeView === "analytics" && (
        <div className="space-y-6">
          <h2 className="text-2xl font-bold">Analytics y Métricas</h2>
          
          {/* Stats Cards */}
          <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
            <div className={`rounded-xl border p-5 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <div className="flex items-center justify-between mb-2">
                <p className={`text-sm font-medium ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                  Score Promedio
                </p>
                <IconStar className="w-6 h-6 text-yellow-400" />
              </div>
              <p className="text-3xl font-bold text-primary-500">{avgScore}</p>
            </div>
            <div className={`rounded-xl border p-5 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <div className="flex items-center justify-between mb-2">
                <p className={`text-sm font-medium ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                  Matches Activos
                </p>
                <IconMatches className="w-6 h-6 text-blue-400" />
              </div>
              <p className="text-3xl font-bold">{activeMatches.length}</p>
            </div>
            <div className={`rounded-xl border p-5 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <div className="flex items-center justify-between mb-2">
                <p className={`text-sm font-medium ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                  Tasa de Éxito
                </p>
                <IconChart className="w-6 h-6 text-green-400" />
              </div>
              <p className="text-3xl font-bold">
                {matches.length > 0 ? ((completedMatches.length / matches.length) * 100).toFixed(1) : 0}%
              </p>
            </div>
            <div className={`rounded-xl border p-5 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <div className="flex items-center justify-between mb-2">
                <p className={`text-sm font-medium ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                  Participantes
                </p>
                <IconParticipants className="w-6 h-6 text-green-400" />
              </div>
              <p className="text-3xl font-bold">{participants.length}</p>
            </div>
          </div>

          {/* Charts */}
          <div className="grid gap-4 md:grid-cols-2">
            <div className={`rounded-xl border p-5 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <h3 className="mb-4 text-base font-semibold">Distribución de Participantes</h3>
              <div className="h-64 flex items-center justify-center">
                <Doughnut 
                  data={participantData}
                  options={{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                      legend: {
                        position: 'bottom',
                        labels: {
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 12 }
                        }
                      }
                    }
                  }}
                />
              </div>
            </div>

            <div className={`rounded-xl border p-5 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <h3 className="mb-4 text-base font-semibold">Estado de Matches</h3>
              <div className="h-64 flex items-center justify-center">
                <Doughnut 
                  data={matchStatusData}
                  options={{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                      legend: {
                        position: 'bottom',
                        labels: {
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 12 }
                        }
                      }
                    }
                  }}
                />
              </div>
            </div>

            <div className={`rounded-xl border p-5 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <h3 className="mb-4 text-base font-semibold">Matches por Programa</h3>
              <div className="h-64">
                <Bar 
                  data={programData}
                  options={{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                      legend: { display: false }
                    },
                    scales: {
                      y: {
                        beginAtZero: true,
                        ticks: { 
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 11 }
                        },
                        grid: {
                          color: darkMode ? '#1f2937' : '#e5e7eb'
                        }
                      },
                      x: {
                        ticks: { 
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 11 }
                        },
                        grid: {
                          display: false
                        }
                      }
                    }
                  }}
                />
              </div>
            </div>

            <div className={`rounded-xl border p-5 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <h3 className="mb-4 text-base font-semibold">Distribución de Scores</h3>
              <div className="h-64">
                <Bar 
                  data={scoreDistributionData}
                  options={{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                      legend: { display: false }
                    },
                    scales: {
                      y: {
                        beginAtZero: true,
                        ticks: { 
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 11 },
                          stepSize: 1
                        },
                        grid: {
                          color: darkMode ? '#1f2937' : '#e5e7eb'
                        }
                      },
                      x: {
                        ticks: { 
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 11 }
                        },
                        grid: {
                          display: false
                        }
                      }
                    }
                  }}
                />
              </div>
            </div>
          </div>
        </div>
      )}

      {/* VISTA: Reportes */}
      {activeView === "reports" && (
        <div className="space-y-4">
          <h2 className="text-2xl font-bold mb-4">Reportes y Exportación</h2>
          
          {/* Exportar datos */}
          <div className="grid gap-4 md:grid-cols-3">
            <div className={`rounded-xl border p-6 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <h3 className="text-lg font-semibold mb-3 flex items-center gap-2">
                <IconProgram className="w-5 h-5" />
                Programas
              </h3>
              <p className={`text-sm mb-4 ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                Exportar datos de {programs.length} programas
              </p>
              <ExportButton
                data={programs}
                filename="programas"
                type="programs"
                darkMode={darkMode}
              />
            </div>

            <div className={`rounded-xl border p-6 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <h3 className="text-lg font-semibold mb-3 flex items-center gap-2">
                <IconParticipants className="w-5 h-5" />
                Participantes
              </h3>
              <p className={`text-sm mb-4 ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                Exportar datos de {participants.length} participantes
              </p>
              <ExportButton
                data={participants}
                filename="participantes"
                type="participants"
                darkMode={darkMode}
              />
            </div>

            <div className={`rounded-xl border p-6 ${darkMode ? "border-gray-800 bg-dark-400" : "border-gray-200 bg-gray-50"}`}>
              <h3 className="text-lg font-semibold mb-3 flex items-center gap-2">
                <IconMatches className="w-5 h-5" />
                Matches
              </h3>
              <p className={`text-sm mb-4 ${darkMode ? "text-gray-400" : "text-gray-600"}`}>
                Exportar datos de {matches.length} matches
              </p>
              <ExportButton
                data={matches}
                filename="matches"
                type="matches"
                darkMode={darkMode}
              />
            </div>
          </div>
        </div>
      )}

      {/* Modals */}
      <ProgramWizard
        isOpen={programModalOpen}
        onClose={() => setProgramModalOpen(false)}
        onSubmit={async (data) => {
          console.log("🎯 AdminDashboard: onSubmit llamado con data:", data);
          try {
            console.log("📡 Llamando a ApiClient.createProgram...");
            const result = await ApiClient.createProgram(data);
            console.log("✅ Programa creado exitosamente:", result);
            loadData();
            setProgramModalOpen(false);
          } catch (error) {
            console.error("❌ Error creando programa:", error);
            alert("Error al crear programa: " + (error instanceof Error ? error.message : String(error)));
            throw error; // Re-lanzar el error para que el wizard lo maneje
          }
        }}
        darkMode={darkMode}
      />

      <ParticipantModal
        isOpen={participantModalOpen}
        onClose={() => setParticipantModalOpen(false)}
        onSubmit={async (data) => {
          try {
            await ApiClient.createParticipant({ ...data, program_id: programs[0]?.id || 1 });
            loadData();
            setParticipantModalOpen(false);
          } catch (error) {
            console.error("Error agregando participante:", error);
            alert("Error al agregar participante");
          }
        }}
        darkMode={darkMode}
      />

      <CSVUploadModal
        isOpen={csvModalOpen}
        onClose={() => setCSVModalOpen(false)}
        onUpload={async (data) => {
          try {
            const programId = programs[0]?.id || 1;
            for (const row of data) {
              await ApiClient.createParticipant({
                full_name: row.full_name,
                role: row.role,
                headline: row.headline,
                skills: row.skills?.split(";") || [],
                goals: row.goals?.split(";") || [],
                availability_hours: parseInt(row.availability_hours) || 2,
                program_id: programId,
              });
            }
            loadData();
            setCSVModalOpen(false);
          } catch (error) {
            console.error("Error importando CSV:", error);
            alert("Error al importar CSV");
          }
        }}
        darkMode={darkMode}
      />

      <MatchingEngine
        isOpen={matchingEngineOpen}
        onClose={() => setMatchingEngineOpen(false)}
        onExecute={async (programId) => {
          try {
            await ApiClient.smartMatch(programId);
            loadData();
            setMatchingEngineOpen(false);
          } catch (error) {
            console.error("Error ejecutando matching:", error);
            alert("Error al ejecutar matching");
          }
        }}
        participants={participants}
        darkMode={darkMode}
      />

      {/* Chat Window */}
      {activeChatMatch && (
        <ChatWindow
          matchId={activeChatMatch.id}
          currentUserId={userId}
          currentUserName={username}
          recipientName={
            role === "mentor"
              ? activeChatMatch.mentee.full_name
              : activeChatMatch.mentor.full_name
          }
          darkMode={darkMode}
          onClose={() => setActiveChatMatch(null)}
        />
      )}

      {/* Goals & OKRs */}
      {activeGoalsMatch && (
        <GoalsOKRs
          match={activeGoalsMatch}
          darkMode={darkMode}
          onClose={() => setActiveGoalsMatch(null)}
        />
      )}

      {/* AI Assistant */}
      {activeAIMatch && (
        <AIAssistant
          match={activeAIMatch}
          darkMode={darkMode}
          onClose={() => setActiveAIMatch(null)}
        />
      )}

      {/* VISTA: Gestión de Usuarios */}
      {activeView === "users" && (
        <UserManagement darkMode={darkMode} />
      )}

      {/* VISTA: Migración de Datos */}
      {activeView === "migration" && (
        <DataMigration darkMode={darkMode} />
      )}
    </div>
  );
}
