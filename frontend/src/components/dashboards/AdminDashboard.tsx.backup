                          font: { size: 10 },
                          stepSize: 1,
                        },
                        grid: {
                          color: darkMode ? '#374151' : '#e5e7eb',
                        },
                      },
                      x: {
                        ticks: { 
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 9 },
                        },
                        grid: { display: false },
                      }
                    }
                  }}
                />
                </div>
              </div>
            </div>
            </div>
          </div>
        </>
