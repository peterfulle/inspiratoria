interface AdminDashboardProps {
  userId: number;
  username: string;
  role: string;
  darkMode: boolean;
  activeView: string;
  onViewChange: (view: string) => void;
}

export default function AdminDashboard({
  userId,
  username,
  role,
  darkMode,
  activeView,
  onViewChange,
}: AdminDashboardProps) {
  const [programs, setPrograms] = useState<Program[]>([]);
  const [matches, setMatches] = useState<Match[]>([]);
  const [participants, setParticipants] = useState<Participant[]>([]);
  const [loading, setLoading] = useState(true);
  const [matchRatings, setMatchRatings] = useState<{ [key: number]: number }>({});
  const [filters, setFilters] = useState<FilterState>({ search: "", role: "all", status: "all" });
  
  // Modals
  const [programModalOpen, setProgramModalOpen] = useState(false);
  const [participantModalOpen, setParticipantModalOpen] = useState(false);
  const [csvModalOpen, setCSVModalOpen] = useState(false);
  const [matchingEngineOpen, setMatchingEngineOpen] = useState(false);
  const [activeChatMatch, setActiveChatMatch] = useState<Match | null>(null);
  const [activeGoalsMatch, setActiveGoalsMatch] = useState<Match | null>(null);
  const [activeAIMatch, setActiveAIMatch] = useState<Match | null>(null);
  const [programDetailsOpen, setProgramDetailsOpen] = useState(false);
  const [selectedProgram, setSelectedProgram] = useState<Program | null>(null);
  
  const router = useRouter();

  useEffect(() => {
    loadData();
  }, []);

  const loadData = () => {
    Promise.all([
      ApiClient.getPrograms(),
      ApiClient.getMatches(),
      ApiClient.getParticipants(),
    ])
      .then(([progs, matchs, parts]) => {
        setPrograms(progs);
        setMatches(matchs);
        setParticipants(parts);
      })
      .catch((err) => {
        console.error("Error cargando datos:", err);
      })
      .finally(() => setLoading(false));
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-[400px]">
        <div className="text-center">
          <div className="mb-4 h-12 w-12 animate-spin rounded-full border-4 border-primary-500 border-t-transparent mx-auto"></div>
          <p className={darkMode ? "text-gray-400" : "text-gray-600"}>Cargando datos...</p>
        </div>
      </div>
    );
  }

  const mentors = participants.filter((p) => p.role === "mentor");
  const mentees = participants.filter((p) => p.role === "mentee");
  const avgScore = matches.length > 0
    ? (matches.reduce((sum, m) => sum + m.score, 0) / matches.length).toFixed(1)
    : "0";
  
  const activeMatches = matches.filter((m) => m.status === "active");
  const completedMatches = matches.filter((m) => m.status === "completed");

  // Filtrar datos
  const filteredParticipants = participants.filter((p) => {
    const matchesSearch = p.full_name.toLowerCase().includes(filters.search.toLowerCase()) ||
                         p.headline?.toLowerCase().includes(filters.search.toLowerCase());
    const matchesRole = filters.role === "all" || p.role === filters.role;
    return matchesSearch && matchesRole;
  });

  const filteredMatches = matches.filter((m) => {
    const matchesSearch = m.mentor.full_name.toLowerCase().includes(filters.search.toLowerCase()) ||
                         m.mentee.full_name.toLowerCase().includes(filters.search.toLowerCase());
    const matchesStatus = filters.status === "all" || m.status === filters.status;
    return matchesSearch && matchesStatus;
  });

  // Chart data
  const participantData = {
    labels: ["Mentores", "Mentees"],
    datasets: [
      {
        data: [mentors.length, mentees.length],
        backgroundColor: ["#FFD902", "#1a1a1a"],
        borderWidth: 2,
        borderColor: darkMode ? "#333" : "#fff",
      },
    ],
  };

  const programData = {
    labels: programs.map((p) => p.name),
    datasets: [
      {
        label: "Matches",
        data: programs.map((p) => matches.filter((m) => m.program_id === p.id).length),
        backgroundColor: "#FFD902",
        borderRadius: 8,
      },
    ],
  };

  const matchStatusData = {
    labels: ["Activos", "Completados", "Pendientes"],
    datasets: [
      {
        data: [
          matches.filter((m) => m.status === "active").length,
          matches.filter((m) => m.status === "completed").length,
          matches.filter((m) => m.status === "pending").length,
        ],
        backgroundColor: ["#10b981", "#FFD902", "#6b7280"],
        borderWidth: 2,
        borderColor: darkMode ? "#000" : "#fff",
      },
    ],
  };

  const scoreDistributionData = {
    labels: ["90-100", "80-89", "70-79", "60-69", "<60"],
    datasets: [
      {
        label: "Matches",
        data: [
          matches.filter((m) => m.score >= 90).length,
          matches.filter((m) => m.score >= 80 && m.score < 90).length,
          matches.filter((m) => m.score >= 70 && m.score < 80).length,
          matches.filter((m) => m.score >= 60 && m.score < 70).length,
          matches.filter((m) => m.score < 60).length,
        ],
        backgroundColor: "#FFD902",
        borderRadius: 8,
      },
    ],
  };

  return (
    <div className="space-y-6">
      {/* VISTA: Dashboard Overview */}
      {activeView === "dashboard" && (
        <>
          {/* Professional Header */}
          <div className="mb-8">
            <div className={`border-b ${darkMode ? 'border-gray-800' : 'border-gray-200'} pb-6`}>
              <div className="flex items-center justify-between">
                <div>
                  <h1 className={`text-3xl font-semibold mb-2 ${darkMode ? 'text-white' : 'text-gray-900'}`}>
                    Dashboard
                  </h1>
                  <p className={`text-sm ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                    Vista general del sistema de mentorías
                  </p>
                </div>
                <div className={`px-4 py-2 rounded-lg text-sm font-medium ${
                  darkMode ? 'bg-gray-800 text-gray-300' : 'bg-gray-100 text-gray-700'
                }`}>
                  {new Date().toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
                </div>
              </div>
            </div>
          </div>

          {/* Professional KPI Cards */}
          <div className="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
            {/* Programas Card */}
            <div className={`rounded-lg p-6 border transition-all duration-200 hover:shadow-lg ${
              darkMode 
                ? 'bg-gray-800/50 border-gray-700/50' 
                : 'bg-white border-gray-200 shadow-sm'
            }`}>
              <div className="flex items-start justify-between mb-4">
                <div className={`p-2.5 rounded-lg ${darkMode ? 'bg-gray-700/50' : 'bg-gray-50'}`}>
                  <IconProgram className={`w-5 h-5 ${darkMode ? 'text-gray-300' : 'text-gray-600'}`} />
                </div>
                <span className={`text-xs font-medium px-2 py-1 rounded ${darkMode ? 'bg-green-500/10 text-green-400' : 'bg-green-50 text-green-700'}`}>
                  +12%
                </span>
              </div>
              <div>
                <p className={`text-sm font-medium mb-1 ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Programas Activos</p>
                <p className={`text-3xl font-bold ${darkMode ? 'text-white' : 'text-gray-900'}`}>{programs.length}</p>
                <p className={`text-xs mt-2 ${darkMode ? 'text-gray-500' : 'text-gray-500'}`}>
                  {activeMatches.length} matches en curso
                </p>
              </div>
            </div>

            {/* Matches Card */}
            <div className={`rounded-lg p-6 border transition-all duration-200 hover:shadow-lg ${
              darkMode 
                ? 'bg-gray-800/50 border-gray-700/50' 
                : 'bg-white border-gray-200 shadow-sm'
            }`}>
              <div className="flex items-start justify-between mb-4">
                <div className={`p-2.5 rounded-lg ${darkMode ? 'bg-gray-700/50' : 'bg-gray-50'}`}>
                  <IconMatches className={`w-5 h-5 ${darkMode ? 'text-gray-300' : 'text-gray-600'}`} />
                </div>
                <span className={`text-xs font-medium px-2 py-1 rounded ${darkMode ? 'bg-green-500/10 text-green-400' : 'bg-green-50 text-green-700'}`}>
                  +8%
                </span>
              </div>
              <div>
                <p className={`text-sm font-medium mb-1 ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Total Matches</p>
                <p className={`text-3xl font-bold ${darkMode ? 'text-white' : 'text-gray-900'}`}>{matches.length}</p>
                <p className={`text-xs mt-2 ${darkMode ? 'text-gray-500' : 'text-gray-500'}`}>
                  {completedMatches.length} completados exitosamente
                </p>
              </div>
            </div>

            {/* Participantes Card */}
            <div className={`rounded-lg p-6 border transition-all duration-200 hover:shadow-lg ${
              darkMode 
                ? 'bg-gray-800/50 border-gray-700/50' 
                : 'bg-white border-gray-200 shadow-sm'
            }`}>
              <div className="flex items-start justify-between mb-4">
                <div className={`p-2.5 rounded-lg ${darkMode ? 'bg-gray-700/50' : 'bg-gray-50'}`}>
                  <IconParticipants className={`w-5 h-5 ${darkMode ? 'text-gray-300' : 'text-gray-600'}`} />
                </div>
                <span className={`text-xs font-medium px-2 py-1 rounded ${darkMode ? 'bg-green-500/10 text-green-400' : 'bg-green-50 text-green-700'}`}>
                  +15%
                </span>
              </div>
              <div>
                <p className={`text-sm font-medium mb-1 ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Participantes</p>
                <p className={`text-3xl font-bold ${darkMode ? 'text-white' : 'text-gray-900'}`}>{participants.length}</p>
                <p className={`text-xs mt-2 ${darkMode ? 'text-gray-500' : 'text-gray-500'}`}>
                  {mentors.length} mentores · {mentees.length} mentees
                </p>
              </div>
            </div>

            {/* Score Card */}
            <div className={`rounded-lg p-6 border transition-all duration-200 hover:shadow-lg ${
              darkMode 
                ? 'bg-gray-800/50 border-gray-700/50' 
                : 'bg-white border-gray-200 shadow-sm'
            }`}>
              <div className="flex items-start justify-between mb-4">
                <div className={`p-2.5 rounded-lg ${darkMode ? 'bg-gray-700/50' : 'bg-gray-50'}`}>
                  <IconStar className={`w-5 h-5 ${darkMode ? 'text-gray-300' : 'text-gray-600'}`} />
                </div>
                <span className={`text-xs font-medium px-2 py-1 rounded ${darkMode ? 'bg-green-500/10 text-green-400' : 'bg-green-50 text-green-700'}`}>
                  +5%
                </span>
              </div>
              <div>
                <p className={`text-sm font-medium mb-1 ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Calidad Promedio</p>
                <p className={`text-3xl font-bold ${darkMode ? 'text-white' : 'text-gray-900'}`}>{avgScore}%</p>
                <p className={`text-xs mt-2 ${darkMode ? 'text-gray-500' : 'text-gray-500'}`}>
                  Score de matching
                </p>
              </div>
            </div>
          </div>

          {/* Professional Action Bar */}
          <div className={`rounded-lg p-6 border ${
            darkMode 
              ? 'bg-gray-800/30 border-gray-700/50' 
              : 'bg-gray-50/50 border-gray-200'
          }`}>
            <div className="flex items-center justify-between mb-4">
              <h3 className={`text-sm font-semibold uppercase tracking-wider ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                Acciones Rápidas
              </h3>
            </div>
            <div className="grid gap-3 grid-cols-2 md:grid-cols-4">
              <button
                onClick={() => setProgramModalOpen(true)}
                className={`px-4 py-3 rounded-lg font-medium text-sm transition-colors flex items-center justify-center gap-2 ${
                  darkMode
                    ? 'bg-blue-600 hover:bg-blue-700 text-white'
                    : 'bg-blue-600 hover:bg-blue-700 text-white'
                }`}
              >
                <IconProgram className="w-4 h-4" />
                <span>Nuevo Programa</span>
              </button>
              
              <button
                onClick={() => setParticipantModalOpen(true)}
                className={`px-4 py-3 rounded-lg font-medium text-sm transition-colors flex items-center justify-center gap-2 border ${
                  darkMode 
                    ? 'bg-gray-800 hover:bg-gray-700 text-gray-200 border-gray-700' 
                    : 'bg-white hover:bg-gray-50 text-gray-700 border-gray-300'
                }`}
              >
                <IconParticipants className="w-4 h-4" />
                <span>Agregar Participante</span>
              </button>
              
              <button
                onClick={() => setCSVModalOpen(true)}
                className={`px-4 py-3 rounded-lg font-medium text-sm transition-colors flex items-center justify-center gap-2 border ${
                  darkMode 
                    ? 'bg-gray-800 hover:bg-gray-700 text-gray-200 border-gray-700' 
                    : 'bg-white hover:bg-gray-50 text-gray-700 border-gray-300'
                }`}
              >
                <IconDocument className="w-4 h-4" />
                <span>Importar CSV</span>
              </button>
              
              <button
                onClick={() => setMatchingEngineOpen(true)}
                className={`px-4 py-3 rounded-lg font-medium text-sm transition-colors flex items-center justify-center gap-2 border ${
                  darkMode 
                    ? 'bg-gray-800 hover:bg-gray-700 text-gray-200 border-gray-700' 
                    : 'bg-white hover:bg-gray-50 text-gray-700 border-gray-300'
                }`}
              >
                <IconAI className="w-4 h-4" />
                <span>Ejecutar Matching</span>
              </button>
            </div>
          </div>

          {/* Professional Analytics Section */}
          <div>
            <h3 className={`text-sm font-semibold uppercase tracking-wider mb-4 ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>
              Análisis y Métricas
            </h3>
            <div className="grid gap-5 grid-cols-1 md:grid-cols-2 xl:grid-cols-4">
              {/* Chart 1: Distribución */}
              <div className={`rounded-lg p-6 border transition-all duration-200 hover:shadow-lg ${
                darkMode 
                  ? 'bg-gray-800/50 border-gray-700/50' 
                  : 'bg-white border-gray-200 shadow-sm'
              }`}>
                <div className="flex items-center justify-between mb-4">
                  <h4 className={`text-sm font-semibold ${darkMode ? 'text-white' : 'text-gray-900'}`}>
                    Distribución de Roles
                  </h4>
                  <IconParticipants className={`w-4 h-4 ${darkMode ? 'text-gray-400' : 'text-gray-500'}`} />
                </div>
                <div className="h-48">
                  <Doughnut 
                  data={participantData}
                  options={{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                      legend: {
                        position: 'bottom',
                        labels: {
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 13, weight: 'bold' },
                          padding: 15,
                          usePointStyle: true,
                          pointStyle: 'circle',
                        }
                      },
                      tooltip: {
                        backgroundColor: darkMode ? '#1f2937' : '#ffffff',
                        titleColor: darkMode ? '#ffffff' : '#000000',
                        bodyColor: darkMode ? '#9ca3af' : '#4b5563',
                        borderColor: darkMode ? '#374151' : '#e5e7eb',
                        borderWidth: 1,
                        padding: 12,
                        displayColors: true,
                        callbacks: {
                          label: function(context) {
                            const label = context.label || '';
                            const value = context.parsed || 0;
                            const total = context.dataset.data.reduce((a: number, b: number) => a + b, 0);
                            const percentage = ((value / total) * 100).toFixed(1);
                            return `${label}: ${value} (${percentage}%)`;
                          }
                        }
                      }
                    },
                    cutout: '65%',
                  }}
                />
                </div>
              </div>
            </div>

              {/* Chart 2: Estado Matches */}
              <div className={`rounded-lg p-6 border transition-all duration-200 hover:shadow-lg ${
                darkMode 
                  ? 'bg-gray-800/50 border-gray-700/50' 
                  : 'bg-white border-gray-200 shadow-sm'
              }`}>
                <div className="flex items-center justify-between mb-4">
                  <h4 className={`text-sm font-semibold ${darkMode ? 'text-white' : 'text-gray-900'}`}>
                    Estado de Matches
                  </h4>
                  <IconChart className={`w-4 h-4 ${darkMode ? 'text-gray-400' : 'text-gray-500'}`} />
                </div>
                <div className="h-48">
                  <Doughnut 
                  data={matchStatusData}
                  options={{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                      legend: {
                        position: 'bottom',
                        labels: {
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 11 },
                          padding: 8,
                        }
                      },
                    },
                    cutout: '60%',
                  }}
                />
                </div>
              </div>
            </div>

              {/* Chart 3: Por Programa */}
              <div className={`rounded-lg p-6 border transition-all duration-200 hover:shadow-lg ${
                darkMode 
                  ? 'bg-gray-800/50 border-gray-700/50' 
                  : 'bg-white border-gray-200 shadow-sm'
              }`}>
                <div className="flex items-center justify-between mb-4">
                  <h4 className={`text-sm font-semibold ${darkMode ? 'text-white' : 'text-gray-900'}`}>
                    Matches por Programa
                  </h4>
                  <IconProgram className={`w-4 h-4 ${darkMode ? 'text-gray-400' : 'text-gray-500'}`} />
                </div>
                <div className="h-48">
                  <Bar 
                  data={programData}
                  options={{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                      legend: { display: false },
                    },
                    scales: {
                      y: {
                        beginAtZero: true,
                        ticks: { 
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 10 },
                        },
                        grid: {
                          color: darkMode ? '#374151' : '#e5e7eb',
                        },
                      },
                      x: {
                        ticks: { 
                          color: darkMode ? '#9ca3af' : '#4b5563',
                          font: { size: 9 },
                        },
                        grid: { display: false },
                      }
                    }
                  }}
                />
                </div>
              </div>

              {/* Chart 4: Scores */}
              <div className={`rounded-lg p-6 border transition-all duration-200 hover:shadow-lg ${
                darkMode 
                  ? 'bg-gray-800/50 border-gray-700/50' 
                  : 'bg-white border-gray-200 shadow-sm'
