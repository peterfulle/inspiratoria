"use client";

import { useParams, useRouter } from "next/navigation";
import { useEffect, useState } from "react";
import Link from "next/link";

interface Program {
  id: number;
  name: string;
  description: string;
  theme: string;
  status: string;
  company?: {
    id: string;
    name: string;
  };
  activities?: any[];
  activities_count?: number;
  participants_count?: number;
}

interface ActivityFormData {
  name: string;
  description: string;
  activity_type: "event" | "training";
  training_category?: string;
  event_category?: string;
  modality?: string;
  start_date: string;
  end_date: string;
  target_role?: string;
  has_modules: boolean;
  requires_module_survey: boolean;
  provides_certification: boolean;
  requires_satisfaction_survey: boolean;
  provides_participation_certificate: boolean;
  meeting_url?: string;
  location_address?: string;
}

interface ModuleFormData {
  title: string;
  description: string;
  order: number;
  materials_url?: string;
  duration_hours?: number;
  requires_evaluation: boolean;
  min_score?: number;
}

interface TrainingConfig {
  requires_sequential_completion: boolean;
  min_attendance_percentage: number;
  certification_requirements: string;
  certificate_template?: string;
}

export default function ManageProgramPage() {
  const params = useParams();
  const router = useRouter();
  const programId = params.id as string;
  const [program, setProgram] = useState<Program | null>(null);
  const [loading, setLoading] = useState(true);
  const [activeTab, setActiveTab] = useState<"general" | "activities" | "participants" | "reports">("general");
  const [showActivityModal, setShowActivityModal] = useState(false);
  const [showDayActivitiesModal, setShowDayActivitiesModal] = useState(false);
  const [selectedDayActivities, setSelectedDayActivities] = useState<any[]>([]);
  const [selectedDate, setSelectedDate] = useState<string>("");
  const [savingActivity, setSavingActivity] = useState(false);
  const [wizardStep, setWizardStep] = useState(1); // 1: Básico, 2: Módulos (solo entrenamientos)
  const [modules, setModules] = useState<ModuleFormData[]>([]);
  const [trainingConfig, setTrainingConfig] = useState<TrainingConfig>({
    requires_sequential_completion: true,
    min_attendance_percentage: 80,
    certification_requirements: "Completar todos los módulos y aprobar evaluaciones",
    certificate_template: "default",
  });
  const [activityForm, setActivityForm] = useState<ActivityFormData>({
    name: "",
    description: "",
    activity_type: "event",
    modality: "online",
    start_date: "",
    end_date: "",
    has_modules: false,
    requires_module_survey: false,
    provides_certification: false,
    requires_satisfaction_survey: false,
    provides_participation_certificate: false,
  });

  useEffect(() => {
    loadProgram();
  }, [programId]);

  const loadProgram = async () => {
    try {
      const apiUrl = process.env.NEXT_PUBLIC_API_URL || "http://localhost:8001";
      const response = await fetch(`${apiUrl}/api/programs/${programId}`);
      if (response.ok) {
        const data = await response.json();
        setProgram(data);
      }
    } catch (error) {
      console.error("Error loading program:", error);
    } finally {
      setLoading(false);
    }
  };

  const handleCreateActivity = async () => {
    if (!activityForm.name || !activityForm.start_date) {
      alert("Por favor completa los campos requeridos: Nombre y Fecha de inicio");
      return;
    }

    // Validar campos según modalidad
    if (activityForm.modality === "in_person" && !activityForm.location_address) {
      alert("Por favor ingresa la dirección de la ubicación para eventos presenciales");
      return;
    }

    if (activityForm.modality === "hybrid" && !activityForm.meeting_url && !activityForm.location_address) {
      alert("Por favor completa al menos uno: URL de reunión o dirección física");
      return;
    }

    // Si es entrenamiento con módulos, validar que haya al menos un módulo
    if (activityForm.activity_type === "training" && activityForm.has_modules && modules.length === 0) {
      alert("Por favor agrega al menos un módulo para el entrenamiento");
      return;
    }

    setSavingActivity(true);
    try {
      const apiUrl = process.env.NEXT_PUBLIC_API_URL || "http://localhost:8001";
      
      // Construir el payload completo
      const payload: any = {
        program_id: parseInt(programId),
        name: activityForm.name,
        description: activityForm.description,
        activity_type: activityForm.activity_type,
        start_date: activityForm.start_date,
        end_date: activityForm.end_date || activityForm.start_date,
        has_modules: activityForm.has_modules,
        requires_module_survey: activityForm.requires_module_survey,
        provides_certification: activityForm.provides_certification,
        requires_satisfaction_survey: activityForm.requires_satisfaction_survey,
        provides_participation_certificate: activityForm.provides_participation_certificate,
      };

      // Agregar campos opcionales
      if (activityForm.modality) payload.modality = activityForm.modality;
      if (activityForm.target_role) payload.target_role = activityForm.target_role;
      if (activityForm.meeting_url) payload.meeting_url = activityForm.meeting_url;
      if (activityForm.location_address) payload.location_address = activityForm.location_address;
      
      if (activityForm.activity_type === "training" && activityForm.training_category) {
        payload.training_category = activityForm.training_category;
      }
      if (activityForm.activity_type === "event" && activityForm.event_category) {
        payload.event_category = activityForm.event_category;
      }

      // Si es entrenamiento con módulos, agregar módulos y configuración
      if (activityForm.activity_type === "training" && modules.length > 0) {
        payload.modules = modules;
        payload.training_config = trainingConfig;
      }

      const response = await fetch(`${apiUrl}/api/activities/create`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      if (response.ok) {
        const data = await response.json();
        
        // Mostrar mensaje de éxito
        let message = "✅ Actividad creada exitosamente!";
        if (activityForm.modality === "online" && data.meeting_url) {
          message += `\n\n📹 URL de Google Meet generada:\n${data.meeting_url}`;
        }
        if (modules.length > 0) {
          message += `\n\n📚 ${modules.length} módulo(s) configurado(s)`;
        }
        alert(message);
        
        // Resetear y recargar
        resetModal();
        await loadProgram();
      } else {
        const error = await response.json();
        alert(`Error al crear actividad: ${error.detail || "Error desconocido"}`);
      }
    } catch (error) {
      console.error("Error creating activity:", error);
      alert("Error al crear la actividad");
    } finally {
      setSavingActivity(false);
    }
  };

  const handleDayClick = (day: number, month: number, year: number) => {
    // Buscar actividades para este día
    const dayActivities = (program?.activities || []).filter((activity) => {
      if (!activity.date && !activity.start_date) return false;
      const activityDate = new Date(activity.date || activity.start_date);
      return activityDate.getDate() === day && 
             activityDate.getMonth() === month && 
             activityDate.getFullYear() === year;
    });
    
    if (dayActivities.length > 0) {
      setSelectedDayActivities(dayActivities);
      setSelectedDate(`${day} de ${['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 
        'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'][month]} ${year}`);
      setShowDayActivitiesModal(true);
    }
  };

  const handleAddModule = () => {
    setModules([
      ...modules,
      {
        title: "",
        description: "",
        order: modules.length + 1,
        materials_url: "",
        duration_hours: 0,
        requires_evaluation: false,
        min_score: 70,
      },
    ]);
  };

  const handleRemoveModule = (index: number) => {
    setModules(modules.filter((_, i) => i !== index));
  };

  const handleModuleChange = (index: number, field: keyof ModuleFormData, value: any) => {
    const newModules = [...modules];
    newModules[index] = { ...newModules[index], [field]: value };
    setModules(newModules);
  };

  const handleNextStep = () => {
    // Validar paso 1 antes de avanzar
    if (!activityForm.name || !activityForm.start_date) {
      alert("Por favor completa los campos requeridos: Nombre y Fecha de inicio");
      return;
    }

    if (activityForm.modality === "in_person" && !activityForm.location_address) {
      alert("Por favor ingresa la dirección de la ubicación para eventos presenciales");
      return;
    }

    if (activityForm.modality === "hybrid" && !activityForm.meeting_url && !activityForm.location_address) {
      alert("Por favor completa al menos uno: URL de reunión o dirección física");
      return;
    }

    setWizardStep(2);
  };

  const handlePreviousStep = () => {
    setWizardStep(1);
  };

  const resetModal = () => {
    setShowActivityModal(false);
    setWizardStep(1);
    setModules([]);
    setActivityForm({
      name: "",
      description: "",
      activity_type: "event",
      modality: "online",
      start_date: "",
      end_date: "",
      has_modules: false,
      requires_module_survey: false,
      provides_certification: false,
      requires_satisfaction_survey: false,
      provides_participation_certificate: false,
      meeting_url: "",
      location_address: "",
    });
    setTrainingConfig({
      requires_sequential_completion: true,
      min_attendance_percentage: 80,
      certification_requirements: "Completar todos los módulos y aprobar evaluaciones",
      certificate_template: "default",
    });
  };

  if (loading) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary-500 mx-auto"></div>
          <p className="mt-4 text-gray-600">Cargando programa...</p>
        </div>
      </div>
    );
  }

  if (!program) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <p className="text-red-600 font-bold">Programa no encontrado</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50 p-8">
      <div className="max-w-7xl mx-auto">
        {/* Breadcrumb Navigation */}
        <nav className="flex items-center gap-2 text-sm mb-6">
          <Link href="/dashboard" className="text-gray-500 hover:text-gray-900 font-medium">
            Dashboard
          </Link>
          <svg className="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5l7 7-7 7" />
          </svg>
          <Link href="/dashboard/programs" className="text-gray-500 hover:text-gray-900 font-medium">
            Programas
          </Link>
          <svg className="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5l7 7-7 7" />
          </svg>
          <span className="text-gray-900 font-bold">{program.name}</span>
        </nav>

        {/* Header */}
        <div className="bg-white rounded-xl border-2 border-gray-200 p-6 mb-6">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-4">
              <div className="w-16 h-16 bg-gradient-to-br from-primary-400 to-primary-600 rounded-xl flex items-center justify-center">
                <svg className="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <div>
                <h1 className="text-3xl font-bold text-gray-900">{program.name}</h1>
                <div className="flex items-center gap-3 mt-1">
                  <span className="text-gray-600 flex items-center gap-1">
                    <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                    {program.company?.name || "Sin empresa"}
                  </span>
                  <span className="text-gray-400">•</span>
                  <span className="inline-flex items-center gap-1.5 px-2 py-1 rounded-full text-xs font-bold bg-purple-100 text-purple-700 border border-purple-300">
                    {program.status}
                  </span>
                </div>
              </div>
            </div>
            <div className="flex gap-3">
              <button
                onClick={() => router.push('/dashboard/programs')}
                className="px-4 py-2 bg-gray-200 text-gray-700 font-bold rounded-lg hover:bg-gray-300 transition-all flex items-center gap-2"
              >
                <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Volver a Programas
              </button>
            </div>
          </div>
        </div>

        {/* Tabs Navigation */}
        <div className="bg-white rounded-xl border-2 border-gray-200 mb-6">
          <div className="flex border-b-2 border-gray-200">
            <button 
              onClick={() => setActiveTab("general")}
              className={`flex-1 px-6 py-4 font-bold transition-all ${
                activeTab === "general"
                  ? "text-primary-600 border-b-4 border-primary-500 bg-primary-50"
                  : "text-gray-600 hover:bg-gray-50"
              }`}
            >
              <span className="flex items-center justify-center gap-2">
                <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Información General
              </span>
            </button>
            <button 
              onClick={() => setActiveTab("activities")}
              className={`flex-1 px-6 py-4 font-bold transition-all ${
                activeTab === "activities"
                  ? "text-primary-600 border-b-4 border-primary-500 bg-primary-50"
                  : "text-gray-600 hover:bg-gray-50"
              }`}
            >
              <span className="flex items-center justify-center gap-2">
                <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                Actividades
              </span>
            </button>
            <button 
              onClick={() => setActiveTab("participants")}
              className={`flex-1 px-6 py-4 font-bold transition-all ${
                activeTab === "participants"
                  ? "text-primary-600 border-b-4 border-primary-500 bg-primary-50"
                  : "text-gray-600 hover:bg-gray-50"
              }`}
            >
              <span className="flex items-center justify-center gap-2">
                <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                Participantes
              </span>
            </button>
            <button 
              onClick={() => setActiveTab("reports")}
              className={`flex-1 px-6 py-4 font-bold transition-all ${
                activeTab === "reports"
                  ? "text-primary-600 border-b-4 border-primary-500 bg-primary-50"
                  : "text-gray-600 hover:bg-gray-50"
              }`}
            >
              <span className="flex items-center justify-center gap-2">
                <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
                Reportes
              </span>
            </button>
          </div>
        </div>

        {/* Content Area */}
        <div className="grid grid-cols-3 gap-6">
          {/* Main Content */}
          <div className="col-span-2 space-y-6">
            
            {/* TAB: Información General */}
            {activeTab === "general" && (
              <>
                {/* Información del Programa */}
                <div className="bg-white rounded-xl border-2 border-gray-200 p-6">
                  <h2 className="text-xl font-bold text-gray-900 mb-4">Detalles del Programa</h2>
                  <div className="space-y-4">
                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Nombre</label>
                      <p className="text-gray-900">{program.name}</p>
                    </div>
                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Descripción</label>
                      <p className="text-gray-900">{program.description}</p>
                    </div>
                    <div className="grid grid-cols-2 gap-4">
                      <div>
                        <label className="block text-sm font-bold text-gray-700 mb-2">Tema</label>
                        <p className="text-gray-900">{program.theme}</p>
                      </div>
                      <div>
                        <label className="block text-sm font-bold text-gray-700 mb-2">Estado</label>
                        <span className="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-purple-100 text-purple-700 border-2 border-purple-300">
                          {program.status}
                        </span>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Calendario */}
                <div className="bg-white rounded-xl border-2 border-gray-200 p-6">
                  <div className="flex items-center justify-between mb-4">
                    <h2 className="text-xl font-bold text-gray-900">Calendario de Actividades</h2>
                    <div className="flex gap-2">
                      <button className="px-3 py-1 text-sm font-bold text-gray-600 hover:bg-gray-100 rounded-lg">
                        ‹ Anterior
                      </button>
                      <button className="px-4 py-1 text-sm font-bold text-gray-900 bg-gray-100 rounded-lg">
                        Diciembre 2025
                      </button>
                      <button className="px-3 py-1 text-sm font-bold text-gray-600 hover:bg-gray-100 rounded-lg">
                        Siguiente ›
                      </button>
                    </div>
                  </div>
                  
                  {/* Calendar Grid */}
                  <div className="grid grid-cols-7 gap-2">
                    {/* Headers */}
                    {["Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom"].map((day) => (
                      <div key={day} className="text-center text-xs font-bold text-gray-600 py-2">
                        {day}
                      </div>
                    ))}
                    {/* Days */}
                    {Array.from({ length: 35 }, (_, i) => {
                      const day = i - 1; // Ajustar para que empiece en día 1
                      const isCurrentMonth = day > 0 && day <= 31;
                      const isToday = day === 27; // Hoy es 27 de diciembre
                      
                      // Buscar actividades para este día
                      const dayActivities = (program?.activities || []).filter((activity) => {
                        if (!activity.date && !activity.start_date) return false;
                        const activityDate = new Date(activity.date || activity.start_date);
                        return activityDate.getDate() === day && activityDate.getMonth() === 11; // Diciembre = 11
                      });
                      
                      const hasActivities = dayActivities.length > 0;
                      
                      return (
                        <div
                          key={i}
                          onClick={() => isCurrentMonth && hasActivities && handleDayClick(day, 11, 2025)}
                          className={`aspect-square flex flex-col items-center justify-center text-sm rounded-lg relative transition-all ${
                            !isCurrentMonth
                              ? "text-gray-300"
                              : isToday
                              ? "bg-primary-500 text-white font-bold"
                              : hasActivities
                              ? "hover:bg-primary-100 cursor-pointer text-gray-900 hover:scale-105"
                              : "hover:bg-gray-50 text-gray-900"
                          } ${hasActivities ? "font-bold" : ""}`}
                        >
                          {isCurrentMonth && (
                            <>
                              <span>{day}</span>
                              {hasActivities && (
                                <div className="absolute bottom-1 flex gap-0.5">
                                  {dayActivities.slice(0, 3).map((_, idx) => (
                                    <div
                                      key={idx}
                                      className={`w-1.5 h-1.5 rounded-full ${
                                        isToday ? "bg-white" : "bg-primary-500"
                                      }`}
                                    />
                                  ))}
                                </div>
                              )}
                            </>
                          )}
                        </div>
                      );
                    })}
                  </div>
                  
                  <div className="mt-4 pt-4 border-t-2 border-gray-200">
                    <p className="text-sm text-gray-600">
                      <span className="font-bold">{program?.activities_count || 0}</span> actividades programadas este mes
                    </p>
                  </div>
                </div>
              </>
            )}

            {/* TAB: Actividades */}
            {activeTab === "activities" && (
              <>
                <div className="flex items-center justify-between mb-4">
                  <h2 className="text-xl font-bold text-gray-900">Actividades</h2>
                  <button 
                    onClick={() => setShowActivityModal(true)}
                    className="px-4 py-2 bg-primary-500 text-black font-bold rounded-lg hover:bg-primary-600 transition-all"
                  >
                    + Agregar Actividad
                  </button>
                </div>
                {program.activities && program.activities.length > 0 ? (
                  <div className="space-y-3">
                    {program.activities.map((activity, idx) => (
                      <div key={idx} className="bg-white border-2 border-gray-200 rounded-lg p-5 hover:border-primary-300 transition-all">
                        <div className="flex items-start justify-between">
                          <div className="flex-1">
                            <div className="flex items-center gap-3 mb-2">
                              <p className="font-bold text-gray-900 text-lg">{activity.name}</p>
                              <span className={`inline-block px-3 py-1 rounded-full text-xs font-bold ${
                                activity.type === "event" 
                                  ? "bg-purple-100 text-purple-700 border border-purple-300" 
                                  : "bg-blue-100 text-blue-700 border border-blue-300"
                              }`}>
                                {activity.type === "event" ? "📅 Evento" : "🎓 Entrenamiento"}
                              </span>
                              <span className={`inline-block px-3 py-1 rounded-full text-xs font-bold ${
                                activity.status === "scheduled" 
                                  ? "bg-green-100 text-green-700 border border-green-300"
                                  : activity.status === "completed"
                                  ? "bg-gray-100 text-gray-700 border border-gray-300"
                                  : "bg-yellow-100 text-yellow-700 border border-yellow-300"
                              }`}>
                                {activity.status === "scheduled" ? "Programada" : 
                                 activity.status === "completed" ? "Completada" : "Creada"}
                              </span>
                            </div>
                            
                            {activity.description && (
                              <p className="text-sm text-gray-600 mb-3">{activity.description}</p>
                            )}
                            
                            <div className="flex flex-wrap gap-4 text-sm">
                              {(activity.date || activity.start_date) && (
                                <div className="flex items-center gap-1.5 text-gray-600">
                                  <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                  </svg>
                                  <span className="font-medium">
                                    {new Date(activity.date || activity.start_date).toLocaleDateString('es-ES', {
                                      day: '2-digit',
                                      month: 'long',
                                      year: 'numeric',
                                      hour: '2-digit',
                                      minute: '2-digit'
                                    })}
                                  </span>
                                </div>
                              )}
                              
                              {activity.modality && (
                                <div className="flex items-center gap-1.5 text-gray-600">
                                  <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                  </svg>
                                  <span className="font-medium">
                                    {activity.modality === "online" ? "🎥 Online" : 
                                     activity.modality === "in_person" ? "📍 Presencial" : "🔀 Híbrido"}
                                  </span>
                                </div>
                              )}
                              
                              {activity.capacity && (
                                <div className="flex items-center gap-1.5 text-gray-600">
                                  <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                  </svg>
                                  <span className="font-medium">Capacidad: {activity.capacity}</span>
                                </div>
                              )}
                            </div>
                            
                            {/* Mostrar URL de reunión o ubicación */}
                            {activity.meeting_url && (
                              <div className="mt-3 bg-blue-50 border border-blue-200 rounded-lg p-3">
                                <div className="flex items-center gap-2">
                                  <svg className="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                  </svg>
                                  <a 
                                    href={activity.meeting_url} 
                                    target="_blank" 
                                    rel="noopener noreferrer"
                                    className="text-sm text-blue-600 hover:text-blue-800 font-medium hover:underline"
                                  >
                                    {activity.meeting_url}
                                  </a>
                                </div>
                              </div>
                            )}
                            
                            {activity.location_address && (
                              <div className="mt-3 bg-green-50 border border-green-200 rounded-lg p-3">
                                <div className="flex items-start gap-2">
                                  <svg className="w-4 h-4 text-green-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                  </svg>
                                  <span className="text-sm text-green-800 font-medium">{activity.location_address}</span>
                                </div>
                              </div>
                            )}
                          </div>
                          
                          <div className="flex gap-2">
                            <button className="p-2 text-gray-400 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-all">
                              <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                              </svg>
                            </button>
                            <button className="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all">
                              <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                              </svg>
                            </button>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div className="text-center py-8 text-gray-500">
                    <svg className="w-12 h-12 mx-auto mb-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    <p>No hay actividades definidas</p>
                    <p className="text-sm mt-1">Agrega tu primera actividad para comenzar</p>
                  </div>
                )}
              </>
            )}
          </div>

          {/* Sidebar */}
          <div className="space-y-6">
            {/* Stats */}
            <div className="bg-white rounded-xl border-2 border-gray-200 p-6">
              <h3 className="text-lg font-bold text-gray-900 mb-4">Estadísticas</h3>
              <div className="space-y-4">
                <div className="bg-blue-50 border-2 border-blue-200 rounded-lg p-4">
                  <p className="text-sm font-bold text-gray-600">Actividades</p>
                  <p className="text-3xl font-bold text-blue-600 mt-1">{program.activities_count || 0}</p>
                </div>
                <div className="bg-green-50 border-2 border-green-200 rounded-lg p-4">
                  <p className="text-sm font-bold text-gray-600">Participantes</p>
                  <p className="text-3xl font-bold text-green-600 mt-1">{program.participants_count || 0}</p>
                </div>
              </div>
            </div>

            {/* Acciones Rápidas */}
            <div className="bg-white rounded-xl border-2 border-gray-200 p-6">
              <h3 className="text-lg font-bold text-gray-900 mb-4">Acciones Rápidas</h3>
              <div className="space-y-2">
                <button className="w-full px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-lg transition-all text-left flex items-center gap-2">
                  <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4v16m8-8H4" />
                  </svg>
                  Agregar Participantes
                </button>
                <button className="w-full px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-lg transition-all text-left flex items-center gap-2">
                  <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  Programar Evento
                </button>
                <button className="w-full px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-lg transition-all text-left flex items-center gap-2">
                  <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  Generar Reporte
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Modal Agregar Actividad */}
      {showActivityModal && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-xl max-w-4xl w-full max-h-[90vh] overflow-hidden flex flex-col">
            <div className="sticky top-0 bg-white border-b-2 border-gray-200 px-6 py-4">
              <div className="flex items-center justify-between mb-4">
                <h2 className="text-2xl font-bold text-gray-900">
                  {activityForm.activity_type === "training" ? "🎓 Nuevo Entrenamiento" : "📅 Nuevo Evento"}
                </h2>
                <button
                  onClick={resetModal}
                  className="text-gray-400 hover:text-gray-600"
                >
                  <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>

              {/* Stepper - Solo para entrenamientos */}
              {activityForm.activity_type === "training" && (
                <div className="flex items-center justify-center gap-4">
                  <div className="flex items-center">
                    <div className={`w-10 h-10 rounded-full flex items-center justify-center font-bold ${
                      wizardStep === 1 
                        ? "bg-primary-500 text-black" 
                        : "bg-green-500 text-white"
                    }`}>
                      {wizardStep > 1 ? "✓" : "1"}
                    </div>
                    <span className={`ml-2 font-medium ${wizardStep === 1 ? "text-gray-900" : "text-gray-600"}`}>
                      Información Básica
                    </span>
                  </div>

                  <div className="w-16 h-1 bg-gray-300">
                    <div className={`h-full transition-all ${wizardStep > 1 ? "w-full bg-primary-500" : "w-0"}`}></div>
                  </div>

                  <div className="flex items-center">
                    <div className={`w-10 h-10 rounded-full flex items-center justify-center font-bold ${
                      wizardStep === 2 
                        ? "bg-primary-500 text-black" 
                        : "bg-gray-300 text-gray-600"
                    }`}>
                      2
                    </div>
                    <span className={`ml-2 font-medium ${wizardStep === 2 ? "text-gray-900" : "text-gray-600"}`}>
                      Módulos y Configuración
                    </span>
                  </div>
                </div>
              )}
            </div>

            <div className="p-6 overflow-y-auto flex-1">
              {/* PASO 1: Información Básica */}
              {wizardStep === 1 && (
                <div className="space-y-6">
                  <div>
                    <label className="block text-sm font-bold text-gray-700 mb-2">
                      Nombre de la actividad *
                    </label>
                    <input
                      type="text"
                      value={activityForm.name}
                      onChange={(e) => setActivityForm({ ...activityForm, name: e.target.value })}
                      className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                      placeholder="Ej: Workshop de Liderazgo"
                    />
                  </div>

                  <div>
                  <label className="block text-sm font-bold text-gray-700 mb-2">
                    Descripción
                  </label>
                  <textarea
                    value={activityForm.description}
                    onChange={(e) => setActivityForm({ ...activityForm, description: e.target.value })}
                    rows={3}
                    className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                    placeholder="Describe la actividad..."
                  />
                </div>

                <div className="grid grid-cols-2 gap-4">
                  <div>
                    <label className="block text-sm font-bold text-gray-700 mb-2">
                      Tipo de actividad *
                    </label>
                    <select
                      value={activityForm.activity_type}
                      onChange={(e) => setActivityForm({ 
                        ...activityForm, 
                        activity_type: e.target.value as "event" | "training",
                        training_category: undefined,
                        event_category: undefined,
                      })}
                      className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                    >
                      <option value="event">Evento</option>
                      <option value="training">Entrenamiento</option>
                    </select>
                  </div>

                  {activityForm.activity_type === "event" && (
                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">
                        Categoría de evento
                      </label>
                      <select
                        value={activityForm.event_category || ""}
                        onChange={(e) => setActivityForm({ ...activityForm, event_category: e.target.value })}
                        className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                      >
                        <option value="">Selecciona una categoría</option>
                        <option value="talk">Charla</option>
                        <option value="workshop">Workshop</option>
                        <option value="meeting">Encuentro</option>
                        <option value="other">Otro</option>
                      </select>
                    </div>
                  )}

                  {activityForm.activity_type === "training" && (
                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">
                        Categoría de entrenamiento
                      </label>
                      <select
                        value={activityForm.training_category || ""}
                        onChange={(e) => setActivityForm({ ...activityForm, training_category: e.target.value })}
                        className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                      >
                        <option value="">Selecciona una categoría</option>
                        <option value="mentors">Mentores</option>
                        <option value="mentees">Mentees</option>
                        <option value="facilitators">Facilitadores</option>
                        <option value="other">Otro</option>
                      </select>
                    </div>
                  )}
                </div>

                <div className="grid grid-cols-2 gap-4">
                  <div>
                    <label className="block text-sm font-bold text-gray-700 mb-2">
                      Fecha de inicio *
                    </label>
                    <input
                      type="datetime-local"
                      value={activityForm.start_date}
                      onChange={(e) => setActivityForm({ ...activityForm, start_date: e.target.value })}
                      className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                    />
                  </div>

                  <div>
                    <label className="block text-sm font-bold text-gray-700 mb-2">
                      Fecha de finalización
                    </label>
                    <input
                      type="datetime-local"
                      value={activityForm.end_date}
                      onChange={(e) => setActivityForm({ ...activityForm, end_date: e.target.value })}
                      className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                    />
                  </div>
                </div>

                <div>
                  <label className="block text-sm font-bold text-gray-700 mb-2">
                    Modalidad
                  </label>
                  <select
                    value={activityForm.modality || "online"}
                    onChange={(e) => setActivityForm({ ...activityForm, modality: e.target.value })}
                    className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                  >
                    <option value="online">Online</option>
                    <option value="in_person">Presencial</option>
                    <option value="hybrid">Híbrido</option>
                  </select>
                </div>

                {/* Campos condicionales según modalidad */}
                {(activityForm.modality === "online" || activityForm.modality === "hybrid") && (
                  <div className="bg-blue-50 border-2 border-blue-200 rounded-lg p-4">
                    <div className="flex items-center gap-2 mb-3">
                      <svg className="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                      </svg>
                      <label className="text-sm font-bold text-gray-700">
                        URL de Reunión {activityForm.modality === "online" ? "(Se genera automáticamente)" : "(Opcional)"}
                      </label>
                    </div>
                    {activityForm.modality === "online" ? (
                      <div className="text-sm text-gray-600 bg-white rounded-lg p-3 border border-blue-300">
                        <p className="font-medium">✨ Se generará automáticamente una URL de Google Meet al crear la actividad</p>
                        <p className="text-xs mt-1">Ejemplo: https://meet.google.com/abc-defg-hij</p>
                      </div>
                    ) : (
                      <input
                        type="url"
                        value={activityForm.meeting_url || ""}
                        onChange={(e) => setActivityForm({ ...activityForm, meeting_url: e.target.value })}
                        className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                        placeholder="https://meet.google.com/abc-defg-hij"
                      />
                    )}
                  </div>
                )}

                {(activityForm.modality === "in_person" || activityForm.modality === "hybrid") && (
                  <div className="bg-green-50 border-2 border-green-200 rounded-lg p-4">
                    <div className="flex items-center gap-2 mb-3">
                      <svg className="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      <label className="text-sm font-bold text-gray-700">
                        Dirección de la Ubicación {activityForm.modality === "in_person" ? "*" : "(Opcional)"}
                      </label>
                    </div>
                    <input
                      type="text"
                      value={activityForm.location_address || ""}
                      onChange={(e) => setActivityForm({ ...activityForm, location_address: e.target.value })}
                      className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                      placeholder="Ej: Av. Corrientes 1234, CABA, Argentina"
                      required={activityForm.modality === "in_person"}
                    />
                  </div>
                )}

                {/* Opciones específicas por tipo */}
                {activityForm.activity_type === "training" && (
                <div className="border-t-2 border-gray-200 pt-4">
                  <h3 className="text-lg font-bold text-gray-900 mb-3">Configuración de Entrenamiento</h3>
                  <div className="space-y-3">
                    <label className="flex items-center gap-2 cursor-pointer">
                      <input
                        type="checkbox"
                        checked={activityForm.has_modules}
                        onChange={(e) => setActivityForm({ ...activityForm, has_modules: e.target.checked })}
                        className="w-5 h-5 text-primary-500 border-gray-300 rounded focus:ring-primary-500"
                      />
                      <span className="text-sm font-medium text-gray-700">Tiene módulos de contenido</span>
                    </label>
                    <label className="flex items-center gap-2 cursor-pointer">
                      <input
                        type="checkbox"
                        checked={activityForm.requires_module_survey}
                        onChange={(e) => setActivityForm({ ...activityForm, requires_module_survey: e.target.checked })}
                        className="w-5 h-5 text-primary-500 border-gray-300 rounded focus:ring-primary-500"
                      />
                      <span className="text-sm font-medium text-gray-700">Requiere encuesta por módulo</span>
                    </label>
                    <label className="flex items-center gap-2 cursor-pointer">
                      <input
                        type="checkbox"
                        checked={activityForm.provides_certification}
                        onChange={(e) => setActivityForm({ ...activityForm, provides_certification: e.target.checked })}
                        className="w-5 h-5 text-primary-500 border-gray-300 rounded focus:ring-primary-500"
                      />
                      <span className="text-sm font-medium text-gray-700">Otorga certificación</span>
                    </label>
                  </div>
                </div>
                )}

                {activityForm.activity_type === "event" && (
                <div className="border-t-2 border-gray-200 pt-4">
                  <h3 className="text-lg font-bold text-gray-900 mb-3">Configuración de Evento</h3>
                  <div className="space-y-3">
                    <label className="flex items-center gap-2 cursor-pointer">
                      <input
                        type="checkbox"
                        checked={activityForm.requires_satisfaction_survey}
                        onChange={(e) => setActivityForm({ ...activityForm, requires_satisfaction_survey: e.target.checked })}
                        className="w-5 h-5 text-primary-500 border-gray-300 rounded focus:ring-primary-500"
                      />
                      <span className="text-sm font-medium text-gray-700">Requiere encuesta de satisfacción</span>
                    </label>
                    <label className="flex items-center gap-2 cursor-pointer">
                      <input
                        type="checkbox"
                        checked={activityForm.provides_participation_certificate}
                        onChange={(e) => setActivityForm({ ...activityForm, provides_participation_certificate: e.target.checked })}
                        className="w-5 h-5 text-primary-500 border-gray-300 rounded focus:ring-primary-500"
                      />
                      <span className="text-sm font-medium text-gray-700">Otorga certificado de participación</span>
                    </label>
                  </div>
                </div>
                )}

              {/* PASO 2: Módulos y Configuración (solo para entrenamientos) */}
            {wizardStep === 2 && activityForm.activity_type === "training" && (
              <div className="space-y-6">
                  <div className="bg-blue-50 border-2 border-blue-200 rounded-lg p-4">
                    <h3 className="text-lg font-bold text-gray-900 mb-2 flex items-center gap-2">
                      <svg className="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                      Módulos del Entrenamiento
                    </h3>
                    <p className="text-sm text-gray-600">Configura los módulos de contenido que componen el entrenamiento</p>
                  </div>

                  {/* Lista de módulos */}
                  <div className="space-y-4">
                    {modules.map((module, index) => (
                      <div key={index} className="border-2 border-gray-200 rounded-lg p-4 bg-white">
                        <div className="flex items-center justify-between mb-3">
                          <h4 className="font-bold text-gray-900">Módulo {index + 1}</h4>
                          <button
                            onClick={() => handleRemoveModule(index)}
                            className="text-red-500 hover:text-red-700 p-1"
                          >
                            <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                          </button>
                        </div>

                        <div className="grid grid-cols-2 gap-4">
                          <div className="col-span-2">
                            <label className="block text-sm font-bold text-gray-700 mb-1">Título del módulo *</label>
                            <input
                              type="text"
                              value={module.title}
                              onChange={(e) => handleModuleChange(index, "title", e.target.value)}
                              className="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                              placeholder="Ej: Introducción al Liderazgo"
                            />
                          </div>

                          <div className="col-span-2">
                            <label className="block text-sm font-bold text-gray-700 mb-1">Descripción</label>
                            <textarea
                              value={module.description}
                              onChange={(e) => handleModuleChange(index, "description", e.target.value)}
                              rows={2}
                              className="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                              placeholder="Describe el contenido del módulo..."
                            />
                          </div>

                          <div>
                            <label className="block text-sm font-bold text-gray-700 mb-1">Duración (horas)</label>
                            <input
                              type="number"
                              value={module.duration_hours || 0}
                              onChange={(e) => handleModuleChange(index, "duration_hours", parseFloat(e.target.value))}
                              min="0"
                              step="0.5"
                              className="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                            />
                          </div>

                          <div>
                            <label className="block text-sm font-bold text-gray-700 mb-1">URL de Materiales</label>
                            <input
                              type="url"
                              value={module.materials_url || ""}
                              onChange={(e) => handleModuleChange(index, "materials_url", e.target.value)}
                              className="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                              placeholder="https://..."
                            />
                          </div>

                          <div className="col-span-2 flex items-center gap-4">
                            <label className="flex items-center gap-2 cursor-pointer">
                              <input
                                type="checkbox"
                                checked={module.requires_evaluation}
                                onChange={(e) => handleModuleChange(index, "requires_evaluation", e.target.checked)}
                                className="w-4 h-4 text-primary-500 border-gray-300 rounded focus:ring-primary-500"
                              />
                              <span className="text-sm font-medium text-gray-700">Requiere evaluación</span>
                            </label>

                            {module.requires_evaluation && (
                              <div className="flex items-center gap-2">
                                <label className="text-sm font-medium text-gray-700">Puntaje mínimo:</label>
                                <input
                                  type="number"
                                  value={module.min_score || 70}
                                  onChange={(e) => handleModuleChange(index, "min_score", parseInt(e.target.value))}
                                  min="0"
                                  max="100"
                                  className="w-20 px-2 py-1 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                                />
                                <span className="text-sm text-gray-600">%</span>
                              </div>
                            )}
                          </div>
                        </div>
                      </div>
                    ))}

                    <button
                      onClick={handleAddModule}
                      className="w-full py-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-600 hover:border-primary-500 hover:text-primary-600 font-bold transition-all flex items-center justify-center gap-2"
                    >
                      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4v16m8-8H4" />
                      </svg>
                      Agregar Módulo
                    </button>
                  </div>

                  {/* Configuración de Avance y Certificación */}
                  <div className="border-t-2 border-gray-200 pt-6 space-y-4">
                    <h3 className="text-lg font-bold text-gray-900 flex items-center gap-2">
                      <svg className="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Reglas de Avance y Certificación
                    </h3>

                    <label className="flex items-start gap-3">
                      <input
                        type="checkbox"
                        checked={trainingConfig.requires_sequential_completion}
                        onChange={(e) => setTrainingConfig({ ...trainingConfig, requires_sequential_completion: e.target.checked })}
                        className="mt-1 w-5 h-5 text-primary-500 border-gray-300 rounded focus:ring-primary-500"
                      />
                      <div>
                        <span className="text-sm font-bold text-gray-900">Completar módulos en orden secuencial</span>
                        <p className="text-xs text-gray-600 mt-1">Los participantes deben completar cada módulo antes de avanzar al siguiente</p>
                      </div>
                    </label>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">
                        Porcentaje mínimo de asistencia requerido
                      </label>
                      <div className="flex items-center gap-3">
                        <input
                          type="range"
                          min="0"
                          max="100"
                          value={trainingConfig.min_attendance_percentage}
                          onChange={(e) => setTrainingConfig({ ...trainingConfig, min_attendance_percentage: parseInt(e.target.value) })}
                          className="flex-1"
                        />
                        <span className="font-bold text-gray-900 min-w-[50px]">{trainingConfig.min_attendance_percentage}%</span>
                      </div>
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">
                        Requisitos para obtener certificación
                      </label>
                      <textarea
                        value={trainingConfig.certification_requirements}
                        onChange={(e) => setTrainingConfig({ ...trainingConfig, certification_requirements: e.target.value })}
                        rows={3}
                        className="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:border-primary-500 focus:outline-none"
                        placeholder="Describe los requisitos que debe cumplir el participante..."
                      />
                    </div>
                  </div>
                </div>
              )}
            </div>

            {/* Footer con botones dinámicos según el paso */}
            <div className="sticky bottom-0 bg-gray-50 border-t-2 border-gray-200 px-6 py-4 flex items-center justify-between">
              <div>
                {wizardStep === 2 && (
                  <button
                    onClick={handlePreviousStep}
                    disabled={savingActivity}
                    className="px-6 py-2 text-gray-700 font-bold hover:text-gray-900 transition-all disabled:opacity-50 flex items-center gap-2"
                  >
                    <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 19l-7-7 7-7" />
                    </svg>
                    Anterior
                  </button>
                )}
              </div>

              <div className="flex items-center gap-3">
                <button
                  onClick={resetModal}
                  disabled={savingActivity}
                  className="px-6 py-2 bg-gray-200 text-gray-700 font-bold rounded-lg hover:bg-gray-300 transition-all disabled:opacity-50"
                >
                  Cancelar
                </button>

                {wizardStep === 1 && activityForm.activity_type === "training" ? (
                  <button
                    onClick={handleNextStep}
                    disabled={!activityForm.name || !activityForm.start_date}
                    className="px-6 py-2 bg-primary-500 text-black font-bold rounded-lg hover:bg-primary-600 transition-all disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2"
                  >
                    Siguiente
                    <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5l7 7-7 7" />
                    </svg>
                  </button>
                ) : (
                  <button
                    onClick={handleCreateActivity}
                    disabled={savingActivity || !activityForm.name || !activityForm.start_date}
                    className="px-6 py-2 bg-primary-500 text-black font-bold rounded-lg hover:bg-primary-600 transition-all disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2"
                  >
                    {savingActivity ? (
                      <>
                        <div className="animate-spin rounded-full h-4 w-4 border-b-2 border-black"></div>
                        Guardando...
                      </>
                    ) : (
                      <>
                        <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M5 13l4 4L19 7" />
                        </svg>
                        {activityForm.activity_type === "training" && wizardStep === 2 ? "Crear Entrenamiento" : "Crear Actividad"}
                      </>
                    )}
                  </button>
                )}
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Modal Actividades del Día */}
      {showDayActivitiesModal && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-xl max-w-4xl w-full max-h-[85vh] overflow-hidden flex flex-col">
            <div className="bg-gradient-to-r from-primary-500 to-primary-600 px-6 py-5 flex items-center justify-between">
              <div>
                <h2 className="text-2xl font-bold text-gray-900">📅 Actividades del día</h2>
                <p className="text-sm text-gray-700 mt-1 font-medium">{selectedDate}</p>
              </div>
              <button
                onClick={() => setShowDayActivitiesModal(false)}
                className="text-gray-700 hover:text-gray-900 bg-white bg-opacity-50 hover:bg-opacity-100 rounded-lg p-2 transition-all"
              >
                <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <div className="p-6 overflow-y-auto flex-1">
              <div className="flex items-center justify-between mb-4">
                <p className="text-sm text-gray-600">
                  <span className="font-bold text-lg text-gray-900">{selectedDayActivities.length}</span> {selectedDayActivities.length === 1 ? 'actividad programada' : 'actividades programadas'}
                </p>
              </div>

              <div className="space-y-4">
                {selectedDayActivities.map((activity, idx) => (
                  <div key={idx} className="bg-white border-2 border-gray-200 rounded-xl p-5 hover:border-primary-400 hover:shadow-md transition-all">
                    <div className="flex items-start justify-between mb-3">
                      <div className="flex items-center gap-3">
                        <div className={`w-12 h-12 rounded-xl flex items-center justify-center ${
                          activity.type === "event" 
                            ? "bg-purple-100 text-purple-600" 
                            : "bg-blue-100 text-blue-600"
                        }`}>
                          {activity.type === "event" ? (
                            <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                          ) : (
                            <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                            </svg>
                          )}
                        </div>
                        <div>
                          <h3 className="text-lg font-bold text-gray-900">{activity.name}</h3>
                          <div className="flex items-center gap-2 mt-1">
                            <span className={`inline-block px-2 py-1 rounded-full text-xs font-bold ${
                              activity.type === "event" 
                                ? "bg-purple-100 text-purple-700 border border-purple-300" 
                                : "bg-blue-100 text-blue-700 border border-blue-300"
                            }`}>
                              {activity.type === "event" ? "Evento" : "Entrenamiento"}
                            </span>
                            <span className={`inline-block px-2 py-1 rounded-full text-xs font-bold ${
                              activity.status === "scheduled" 
                                ? "bg-green-100 text-green-700 border border-green-300"
                                : "bg-yellow-100 text-yellow-700 border border-yellow-300"
                            }`}>
                              {activity.status === "scheduled" ? "Programada" : "Pendiente"}
                            </span>
                          </div>
                        </div>
                      </div>
                    </div>

                    {activity.description && (
                      <p className="text-sm text-gray-600 mb-3 pl-15">{activity.description}</p>
                    )}

                    <div className="grid grid-cols-2 gap-3 pl-15">
                      {(activity.date || activity.start_date) && (
                        <div className="flex items-center gap-2 text-sm">
                          <svg className="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                          <span className="text-gray-700 font-medium">
                            {new Date(activity.date || activity.start_date).toLocaleTimeString('es-ES', {
                              hour: '2-digit',
                              minute: '2-digit'
                            })}
                          </span>
                        </div>
                      )}

                      {activity.modality && (
                        <div className="flex items-center gap-2 text-sm">
                          <svg className="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                          </svg>
                          <span className="text-gray-700 font-medium">
                            {activity.modality === "online" ? "🎥 Online" : 
                             activity.modality === "in_person" ? "📍 Presencial" : "🔀 Híbrido"}
                          </span>
                        </div>
                      )}
                    </div>

                    {/* URL de reunión o ubicación */}
                    {activity.meeting_url && (
                      <div className="mt-3 bg-blue-50 border border-blue-200 rounded-lg p-3">
                        <div className="flex items-start gap-2">
                          <svg className="w-4 h-4 text-blue-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                          </svg>
                          <div className="flex-1">
                            <p className="text-xs font-bold text-blue-700 mb-1">URL de Reunión</p>
                            <a 
                              href={activity.meeting_url} 
                              target="_blank" 
                              rel="noopener noreferrer"
                              className="text-sm text-blue-600 hover:text-blue-800 font-medium hover:underline break-all"
                            >
                              {activity.meeting_url}
                            </a>
                          </div>
                        </div>
                      </div>
                    )}
                    
                    {activity.location_address && (
                      <div className="mt-3 bg-green-50 border border-green-200 rounded-lg p-3">
                        <div className="flex items-start gap-2">
                          <svg className="w-4 h-4 text-green-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                          </svg>
                          <div className="flex-1">
                            <p className="text-xs font-bold text-green-700 mb-1">Ubicación</p>
                            <span className="text-sm text-green-800 font-medium">{activity.location_address}</span>
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>

            <div className="bg-gray-50 border-t-2 border-gray-200 px-6 py-4 flex items-center justify-between">
              <button
                onClick={() => setActiveTab("activities")}
                className="text-sm text-primary-600 hover:text-primary-700 font-bold hover:underline"
              >
                Ver todas las actividades →
              </button>
              <button
                onClick={() => setShowDayActivitiesModal(false)}
                className="px-6 py-2 bg-gray-200 text-gray-700 font-bold rounded-lg hover:bg-gray-300 transition-all"
              >
                Cerrar
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
